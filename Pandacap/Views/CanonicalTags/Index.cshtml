@using Pandacap.CanonicalTags.Interfaces
@model CanonicalTagsViewModel

<h1>Edit Canonical Tags</h1>

<h2>Mediums</h2>

@{
    await RenderListAsync(Model.ArtMedia, "AddEditMedium");
}

<h2>Characters</h2>

@{
    await RenderListAsync(Model.Characters, "AddEditCharacter");
}

<h2>Settings</h2>

@{
    await RenderListAsync(Model.Settings, "AddEditSetting");
}

<h2>Species</h2>

@{
    await RenderListAsync(Model.Species, "AddEditSpecies");
}

@functions {
    async Task RenderListAsync(IEnumerable<ICanonicalTagTreeDisplayNode> nodes, string action)
    {
        <ul>
            @foreach (var item in nodes)
            {
                <li>
                    <a asp-action="@action" asp-route-id="@item.Id">
                        @item.Name
                    </a>

                    @if (item.Children.Any())
                    {
                        await RenderListAsync(item.Children, action);
                    }
                </li>
            }
        </ul>

        <p>
            <a asp-action="@action">
                Add new
            </a>
        </p>
    }
}
