@using Pandacap.Constants
@using Pandacap.Database
@model UserPostViewModel

@{
    ViewBag.Title = Model.Post.Type == Post.PostType.StatusUpdate
        ? "Status Update"
        : Model.Post.Title;
    ViewBag.UserPost = Model.Post;
}

@if (Model.Post.IsTextPost && DateTimeOffset.UtcNow.AddYears(-1) > Model.Post.PublishedTime)
{
    <div class="card text-bg-warning mb-3" style="max-width: 18rem;">
        <div class="card-body">
            <p class="card-text">This post is more than one year old.</p>
        </div>
    </div>
}

<partial name="_ProfileHeading" />

<div class="container">
    <div class="row">
        <div class="col-12 col-md-6 col-xl-5 offset-xl-1">
            @if (Model.CharacterAppearances.Any())
            {
                <div class="card mb-4">
                    <div class="card-header">
                        Characters
                    </div>
                    <div class="card-body">
                        @foreach (var appearanceModel in Model.CharacterAppearances
                            .OrderBy(a => a.Background))
                        {
                            if (appearanceModel.Character == null)
                            {
                                continue;
                            }

                            <div style="line-height: 2" class="@(appearanceModel.Background ? "small" : "")">
                                <a asp-controller="CanonicalTags" asp-action="Character" asp-route-id="@appearanceModel.Character.Id">@appearanceModel.Character.Name</a>

                                @if (appearanceModel.Species != null)
                                {
                                    @:as a
                                    <a asp-controller="Gallery" asp-action="ByCanonicalTag" asp-route-tagId="@appearanceModel.Species.Id">@appearanceModel.Species.Name</a>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
        <div class="col-12 col-md-6 col-xl-5">
            @if (Model.MediumApplications.Any())
            {
                <div class="card mb-4">
                    <div class="card-header">
                        Mediums
                    </div>
                    <div class="card-body">
                        @foreach (var applicationModel in Model.MediumApplications)
                        {
                            <div style="line-height: 2">
                                <a href="#">@(applicationModel.MediumName ?? $"{applicationModel.MediumId}")</a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="col-12">
                <form asp-action="ReplaceTags">
                    <input type="hidden" name="postId" value="@Model.Post.Id" />
                    <div class="input-group my-3">
                        <span class="input-group-text">Replace canonical tags</span>
                        <input name="canonicalTags"
                        type="text"
                        class="form-control">
                        <button class="btn btn-primary" type="submit">
                            Replace
                        </button>
                    </div>
                </form>
            </div>
        }
    </div>
</div>

<h1>@Model.Post.Title</h1>

<p>
    @Model.Post.PublishedTime.UtcDateTime.ToLongDateString()
    @Model.Post.PublishedTime.UtcDateTime.ToShortTimeString()
</p>

@if (Model.Post.Type != Post.PostType.Scraps)
{
    <div class="mb-3">
        <partial name="_PlatformLinks" model="@Model.PlatformLinks" />
    </div>
}

@foreach (var image in Model.Post.Images)
{
    <p align="center">
        <a href="/Blobs/UserPosts/@Model.Post.Id/@image.Primary.Id" target="_blank">
            <picture>
                <source srcset="/Blobs/UserPosts/@Model.Post.Id/@image.Primary.Id" type="@image.Primary.ContentType" />
                <img src="/Blobs/UserPosts/@Model.Post.Id/@image.Raster.Id"
                     alt="@image.AltText"
                     title="@image.AltText"
                     style="width: 100%; max-width: 640px; max-height: 480px; object-fit: contain" />
            </picture>
        </a>
    </p>

    <p align="center">
        @foreach (var rendition in image.Renditions)
        {
            <a href="/Blobs/UserPosts/@Model.Post.Id/@rendition.Id" target="_blank" class="btn btn-outline-primary btn-sm">
                View (@rendition.ContentType)
            </a>
        }
    </p>
}

@Html.Raw(Model.Post.Html)

@foreach (var link in Model.Post.Links ?? [])
{
    <div class="container-fluid">
        <div class="row">
            @if (link.Image != null)
            {
                <div class="col-lg-4">
                    <p>
                        <img src="@(link.Image ?? "/images/trgray.svg")" style="width: 100%; max-height: 250px; object-fit: contain" alt="" />
                    </p>
                </div>
            }

            <div class="col-lg-8">
                <p>
                    <strong>@link.Title</strong>
                    <br />
                    <span class="small text-muted">
                        @link.SiteName
                    </span>
                </p>

                <p>
                    @link.Description
                </p>

                <p>
                    <a href="@link.Url" target="_blank">
                        View on @link.SiteName
                    </a>
                </p>
            </div>
        </div>
    </div>
}

@if (Model.Post.Tags.Any())
{
    <p>
        @foreach (string tag in Model.Post.Tags)
        {
            <a href="/Profile/Search?q=%23@(Uri.EscapeDataString(tag))">#@tag</a>
        }
    </p>
}

@if (User.Identity?.IsAuthenticated == true)
{
    <details>
        <summary class="mb-3">Actions</summary>

        @if (Model.Post.DeviantArtId == null)
        {
            <form asp-action="Crosspost" asp-controller="DeviantArt" class="mb-3">
                <input type="hidden" name="id" value="@Model.Post.Id" />
                <button type="submit" class="btn btn-success">
                    Post to DeviantArt
                </button>
            </form>
        }
        else
        {
            <form asp-action="Detach" asp-controller="DeviantArt" class="mb-3" onsubmit="return confirm('This will remove the View on DeviantArt button; it will not delete the post from DeviantArt.')'">
                <input type="hidden" name="id" value="@Model.Post.Id" />
                <button type="submit" class="btn btn-warning">
                    Detach DeviantArt post
                </button>
            </form>
        }

        @if (Model.Post.FurAffinitySubmissionId == null && Model.Post.FurAffinityJournalId == null)
        {
            if (Model.Post.Images.Count > 0 && Model.Post.QueuedFurAffinityPost == null)
            {
                <form asp-action="Crosspost" asp-controller="FurAffinity" class="mb-3">
                    <input type="hidden" name="id" value="@Model.Post.Id" />
                    <button type="submit" class="btn btn-success">
                        Post to Fur Affinity
                    </button>
                </form>
            }
        }
        else
        {
            <form asp-action="Detach" asp-controller="FurAffinity" class="mb-3" onsubmit="return confirm('This will remove the View on Fur Affinity button; it will not delete the post from Fur Affinity.')'">
                <input type="hidden" name="id" value="@Model.Post.Id" />
                <button type="submit" class="btn btn-warning">
                    Detach Fur Affinity post
                </button>
            </form>
        }

        @if (Model.Post.WeasylSubmitId == null && Model.Post.WeasylJournalId == null)
        {
            <form asp-action="Crosspost" asp-controller="Weasyl" class="mb-3">
                <input type="hidden" name="id" value="@Model.Post.Id" />
                <button type="submit" class="btn btn-success">
                    Post to Weasyl
                </button>
            </form>
        }
        else
        {
            <form asp-action="Detach" asp-controller="Weasyl" class="mb-3" onsubmit="return confirm('This will remove the View on Weasyl button; it will not delete the post from Weasyl.')'">
                <input type="hidden" name="id" value="@Model.Post.Id" />
                <button type="submit" class="btn btn-warning">
                    Detach Weasyl post
                </button>
            </form>
        }

        <p class="small text-muted mb-3">
            See the About page for more information about how crossposts work.
        </p>

        <form asp-action="Delete" onsubmit="return confirm('Are you sure you want to delete this post from @(UserAgentInformation.ApplicationName)? (This will not delete it from any site it has been crossposted to.)')">
            <input type="hidden" name="id" value="@Model.Post.Id" />
            <button type="submit" class="btn btn-danger">
                Delete from @UserAgentInformation.ApplicationName
            </button>
        </form>
    </details>
}

@if (Model.Replies.Any())
{
    <h2>Comments</h2>

    foreach (var reply in Model.Replies)
    {
        <partial name="_Reply" model="@reply" />
    }
}
