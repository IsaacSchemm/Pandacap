@using Pandacap.ConfigurationObjects
@using Pandacap.PlatformLinks.Interfaces
@inject ApplicationInformation appInfo
@inject IPlatformIconProvider platformIconProvider
@inject IPlatformLinkProvider platformLinkProvider

@{
    var platformLinks = await platformLinkProvider.GetPlatformLinksAsync();
}

<p>
    <img width="50" height="50" src="/Blobs/Avatar" alt="" />
    <span style="display: inline-block; vertical-align: top">
        <strong>@appInfo.Username</strong>

        @if (platformLinks.Where(link => link.Category == PlatformLinkCategory.ActivityPub).FirstOrDefault() is IPlatformLink ap)
        {
            <br />

            <span class="small text-muted" style="user-select: all">@ap.Username</span>

            var icon = await platformIconProvider.ResolveIconAsync(ap.Host);

            <img alt="@ap.PlatformName icon"
                 title="@ap.PlatformName"
                 src="@icon"
                 width="16"
                 height="16" />
        }

        @if (platformLinks.Where(link => link.Category == PlatformLinkCategory.ATProto).FirstOrDefault() is IPlatformLink at)
        {
            <br />

            <span class="small text-muted" style="user-select: all">@at.Username</span>

            var icon = await platformIconProvider.ResolveIconAsync(at.Host);

            <img alt="@at.PlatformName icon"
                 title="@at.PlatformName"
                 src="@icon"
                 width="16"
                 height="16" />
        }
    </span>
</p>