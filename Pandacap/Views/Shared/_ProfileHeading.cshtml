@using Pandacap.Configuration
@using Pandacap.PlatformLinks.Interfaces
@inject IPlatformLinkProvider platformLinkProvider

@{
    var platformLinks = await platformLinkProvider.GetProfileLinksAsync();
}

<p>
    <img width="50" height="50" src="/Blobs/Avatar" alt="" />
    <span style="display: inline-block; vertical-align: top">
        <span class="visually-hidden">
            Handle:
        </span>

        <strong>@DeploymentInformation.Username</strong>

        @if (platformLinks
            .Where(link => link.Category == PlatformLinkCategory.ActivityPub)
            .FirstOrDefault() is IPlatformLink ap)
        {
            <br />

            <span class="visually-hidden">
                ActivityPub / WebFinger handle:
            </span>

            <span class="small text-muted" style="user-select: all">@ap.Username</span>
        }
    </span>
</p>