@using Pandacap.ActivityPub.Replies.Interfaces
@using Pandacap.Data
@model IReply

@{
    var root = Model.Root;
    string username = string.IsNullOrWhiteSpace(root.Username)
        ? root.CreatedBy
        : root.Username;
}

<section aria-label="Comment" class="comment">
    <div class="user">
        <img width="25" height="25" src="@(root.Usericon ?? "/images/trgray.svg")" alt="" />

        <span style="display: inline-block; vertical-align: top">
            <strong>
                @username
            </strong>

            <a class="small" asp-controller="RemotePosts" asp-action="Index" asp-route-id="@root.ObjectId">
                @root.CreatedAt.UtcDateTime.ToString("MMM d")
            </a>
        </span>
    </div>

    @Html.Raw(root.HtmlContent)

    <details class="small actions">
        <summary>Actions</summary>

        <div class="actions-array">
            <a class="btn btn-sm btn-outline-primary" asp-controller="RemotePosts" asp-action="Index" asp-route-id="@root.ObjectId">
                View
            </a>

            @if (root.Remote)
            {
                <form asp-controller="RemoteReplies" asp-action="Forget" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to remove this post from Pandacap?')">
                    <input type="hidden" name="objectId" value="@root.ObjectId" />
                    <button type="submit" class="btn btn-sm btn-danger">Forget</button>
                </form>
            }
        </div>
    </details>

    @foreach (var reply in Model.Replies)
    {
        <partial name="_Reply" model="@reply" />
    }
</section>
